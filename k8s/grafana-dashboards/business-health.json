{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Orders/min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(orders_created_total[5m]) * 60", "legendFormat": "orders/min" }],
      "fieldConfig": { "defaults": { "unit": "opm", "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Payment Success Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "rate(payments_processed_total[5m]) / rate(http_requests_total{route=~\"/webhooks/.*\"}[5m]) * 100", "legendFormat": "success %" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 }] } } }
    },
    {
      "title": "Revenue/sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(payments_processed_total[5m])", "legendFormat": "payments/sec" }],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Failed Transactions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "rate(wallet_errors_total[5m])", "legendFormat": "wallet errors/sec" }],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "palette-classic" } }, "overrides": [{ "matcher": { "id": "byName" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }] }
    },
    {
      "title": "Business Events by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "rate(business_events_total[5m])", "legendFormat": "{{event_type}}" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Wallet Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "expr": "rate(wallet_ops_total[5m])", "legendFormat": "{{operation}} {{status}}" }],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } } }
    },
    {
      "title": "Escrow Stuck Count",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "expr": "count(escrow_status{status=\"created\"} > 300)", "legendFormat": "stuck escrows" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "title": "Cost per Order",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 12 },
      "targets": [{ "expr": "500 / orders_created_total", "legendFormat": "$/order (est)" }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["geocore", "business"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "GeoCore — Business Health",
  "uid": "geocore-business"
}
