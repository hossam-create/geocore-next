# ==========================================
# App / Runtime
# ==========================================
APP_ENV=development
APP_VERSION=dev
APP_BASE_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGIN=http://localhost:3000

# Backend listens on BACKEND_PORT (or PORT fallback)
BACKEND_PORT=8080
PORT=8080

# ==========================================
# Database (PostgreSQL)
# ==========================================
# Prefer DATABASE_URL in production.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/geocore_dev?sslmode=disable

# Fallback discrete DB vars (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=geocore_dev
DB_PORT=5432
DB_SSLMODE=disable

# Alternative libpq-style aliases read by backend
PGHOST=localhost
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=geocore_dev
PGPORT=5432

# ==========================================
# Redis
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# Auth / Security / Observability
# ==========================================
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_too
RATE_LIMIT_WHITELIST=
SENTRY_DSN=
METRICS_TOKEN=change_me_metrics_token

# ==========================================
# AI / Search
# ==========================================
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
GOOGLE_GENAI_API_KEY=
MEILI_MASTER_KEY=
AI_PRICING_URL=

# ==========================================
# Analytics
# ==========================================
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ==========================================
# Storage (Cloudflare R2)
# ==========================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

# ==========================================
# Payments
# ==========================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

COINBASE_COMMERCE_API_KEY=
COINBASE_COMMERCE_WEBHOOK_SECRET=

TABBY_PUBLIC_KEY=
TABBY_SECRET_KEY=
TAMARA_API_KEY=

# ==========================================
# Communications
# ==========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
TWILIO_VERIFY_SERVICE_SID=

# ==========================================
# Realtime / Live
# ==========================================
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ==========================================
# Firebase / Mobile Push
# ==========================================
FIREBASE_SERVICE_ACCOUNT_JSON=

# ==========================================
# Frontend (public vars)
# ==========================================
NEXT_PUBLIC_APP_VERSION=dev
NEXT_PUBLIC_SENTRY_DSN=
