APP_ENV=development
  PORT=8080

  # PostgreSQL
  DB_HOST=localhost
  DB_PORT=5432
  DB_USER=geocore
  DB_PASSWORD=geocore_secret
  DB_NAME=geocore_dev
  DB_SSLMODE=disable

  # Redis
  REDIS_HOST=localhost
  REDIS_PORT=6379
  REDIS_PASSWORD=

  # Auth
  # ⚠️ SECURITY WARNING: Never use placeholder values in production!
  # Generate a secure random string: openssl rand -base64 64
  # Minimum length: 32 characters
  JWT_SECRET=

  # CORS
  FRONTEND_URL=http://localhost:3000

  # App URL (used in email verification links)
  APP_BASE_URL=http://localhost:3000

  # SMTP Email (for email verification)
  # Supported providers: Mailgun, SendGrid, Brevo, Gmail, any SMTP
  # Leave empty in development — tokens will be printed to console instead
  SMTP_HOST=smtp.mailgun.org
  SMTP_PORT=587
  SMTP_USER=postmaster@mail.yourdomain.com
  SMTP_PASS=your-smtp-password
  SMTP_FROM=noreply@geocore.app

  # Payments
  STRIPE_SECRET_KEY=sk_test_...
  STRIPE_WEBHOOK_SECRET=whsec_...
  PAYPAL_CLIENT_ID=
  PAYPAL_CLIENT_SECRET=
  PAYPAL_WEBHOOK_ID=
  # Optional override: defaults by APP_ENV (sandbox when not production)
  PAYPAL_BASE_URL=

  # Storage
  CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

  # Search
  MEILI_HOST=http://localhost:7700
  MEILI_MASTER_KEY=dev_meili_key

  # Observability
  SENTRY_DSN=
  APP_VERSION=0.0.0
  METRICS_TOKEN=