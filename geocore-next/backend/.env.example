APP_ENV=development
  PORT=8080

  # PostgreSQL
  DB_HOST=localhost
  DB_PORT=5432
  DB_USER=geocore
  DB_PASSWORD=geocore_secret
  DB_NAME=geocore_dev
  DB_SSLMODE=disable

  # Redis
  REDIS_HOST=localhost
  REDIS_PORT=6379
  REDIS_PASSWORD=

  # Auth
  JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars

  # CORS
  FRONTEND_URL=http://localhost:3000

  # App URL (used in email verification links)
  APP_BASE_URL=http://localhost:3000

  # SMTP Email (for email verification)
  # Supported providers: Mailgun, SendGrid, Brevo, Gmail, any SMTP
  # Leave empty in development — tokens will be printed to console instead
  SMTP_HOST=smtp.mailgun.org
  SMTP_PORT=587
  SMTP_USER=postmaster@mail.yourdomain.com
  SMTP_PASS=your-smtp-password
  SMTP_FROM=noreply@geocore.app

  # Payments
  STRIPE_SECRET_KEY=sk_test_...
  STRIPE_WEBHOOK_SECRET=whsec_...

  # Storage
  CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

  # Search
  MEILI_HOST=http://localhost:7700
  MEILI_MASTER_KEY=dev_meili_key
  